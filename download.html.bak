  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50:'#eef4ff',100:'#d9e5ff',200:'#bcd2ff',300:'#8eb5ff',400:'#598dff',500:'#3b6eff',600:'#1e4af5',700:'#1737e1',800:'#192eb6',900:'#1b2c8f',950:'#151d57' }
          },
          fontFamily: { sans: ['Inter','system-ui','sans-serif'] },
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
